{
  "name": "laravel-assist-language-server",
  "version": "0.0.1",
  "description": "Laravel-aware language server for the Laravel Assist Zed extension.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eyedroot/zed-laravel-assist.git",
    "directory": "server"
  },
  "files": [
    "dist/index.cjs"
  ],
  "bin": {
    "laravel-assist-language-server": "./dist/index.cjs"
  },
  "scripts": {
    "build": "npm run typecheck && esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.cjs",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "esbuild": "^0.28.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
